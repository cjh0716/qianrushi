<view class="container">
  <view class="section">
    <button class="btn-secondary" bindtap="goBack">返回设备搜索</button>
  </view>

  <view class="section">
    <view class="section-title">设备信息</view>
    <view wx:if="{{isConnected && connectedDevice}}">
      <view class="connected-device">
        <view class="connected-device-icon">
          <text class="icon-text">✓</text>
        </view>
        <view>
          <view class="connected-device-name">{{connectedDevice}}</view>
          <view class="connected-device-status">
            <view class="connect-status"></view>
            <text>已连接</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <view class="empty-icon">
        <text class="icon-text">📟</text>
      </view>
      <view class="empty-text">请先连接设备</view>
      <view class="empty-hint">在"设备搜索"页面连接设备后再进行配置</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">配置参数</view>

    <view class="input-group">
      <view class="input-label">城市名称</view>
      <input 
        class="input-field {{errors.city ? 'error' : ''}}" 
        placeholder="请输入城市名称" 
        maxlength="50"
        value="{{city}}"
        bindinput="onCityInput"
        bindblur="validateCity"
      />
      <view wx:if="{{errors.city}}" class="error-message">{{errors.city}}</view>
    </view>

    <view class="input-group">
      <view class="input-label">WiFi名称 (SSID)</view>
      <input 
        class="input-field {{errors.ssid ? 'error' : ''}}" 
        placeholder="请输入WiFi名称" 
        maxlength="32"
        value="{{ssid}}"
        bindinput="onSsidInput"
        bindblur="validateSsid"
      />
      <view wx:if="{{errors.ssid}}" class="error-message">{{errors.ssid}}</view>
    </view>

    <view class="input-group">
      <view class="input-label">WiFi密码</view>
      <view class="input-wrapper">
        <input 
          class="input-field {{errors.password ? 'error' : ''}}" 
          placeholder="请输入WiFi密码" 
          maxlength="64"
          password="{{showPassword ? false : true}}"
          value="{{password}}"
          bindinput="onPasswordInput"
          bindblur="validatePassword"
        />
        <view class="eye-icon" bindtap="togglePassword">
          <text>{{showPassword ? '👁️' : '🙈'}}</text>
        </view>
      </view>
      <view wx:if="{{errors.password}}" class="error-message">{{errors.password}}</view>
    </view>

    <button class="btn-primary" bindtap="sendConfig" disabled="{{!canSend}}">
      <text>发送配置</text>
    </button>

    <view wx:if="{{showStatus}}" class="status-feedback {{statusType}}">
      <text class="status-icon">{{statusType === 'success' ? '✅' : '❌'}}</text>
      <text>{{statusMessage}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">配置历史</view>
    <view class="history-list">
      <view 
        wx:for="{{history}}" 
        wx:key="city" 
        class="history-item" 
        bindtap="loadHistory"
        data-city="{{item.city}}"
        data-ssid="{{item.ssid}}"
        data-password="{{item.password}}"
      >
        <view class="history-info">
          <view class="history-city">{{item.city}}</view>
          <view class="history-ssid">{{item.ssid}}</view>
        </view>
        <view class="history-delete" bindtap="deleteHistory" data-city="{{item.city}}">
          <text>🗑️</text>
        </view>
      </view>
    </view>
  </view>
</view>