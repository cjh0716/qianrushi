page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333333;
}

.container {
  padding-bottom: 112rpx;
}

.section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background-color: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-primary:disabled {
  background-color: #cccccc;
}

.btn-secondary {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  color: #333333;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.btn-secondary:active {
  opacity: 0.7;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

.input-field.error {
  border-color: #ff4d4f;
  box-shadow: 0 0 0 4rpx rgba(255, 77, 79, 0.1);
}

.input-field::placeholder {
  color: #cccccc;
}

.error-message {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #999999;
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #cccccc;
}

.status-feedback {
  padding: 24rpx;
  border-radius: 16rpx;
  margin-top: 24rpx;
  text-align: center;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.status-feedback.success {
  background-color: #f6ffed;
  color: #52c41a;
  border: 2rpx solid #b7eb8f;
}

.status-feedback.error {
  background-color: #fff2f0;
  color: #ff4d4f;
  border: 2rpx solid #ffccc7;
}

.status-feedback.info {
  background-color: #e6f7ff;
  color: #1890ff;
  border: 2rpx solid #91d5ff;
}

.status-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.searching-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  color: #07c160;
  font-size: 28rpx;
}

.searching-dots {
  display: flex;
  gap: 8rpx;
}

.searching-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #07c160;
  border-radius: 50%;
}

.searching-dot:nth-child(1) {
  animation: searching 1.4s infinite ease-in-out both;
}

.searching-dot:nth-child(2) {
  animation: searching 1.4s infinite ease-in-out both;
  animation-delay: -0.16s;
}

.searching-dot:nth-child(3) {
  animation: searching 1.4s infinite ease-in-out both;
  animation-delay: -0.32s;
}

@keyframes searching {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.connect-status {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #07c160;
  margin-right: 16rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
  100% {
    opacity: 1;
  }
}